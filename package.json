    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "prisma": "^7.8.0",
