    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
