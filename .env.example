# ─── Database (Supabase / PostgreSQL) ───────────────────────────────────────
# Prisma uses DATABASE_URL for connection pooling and DIRECT_URL for migrations
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Long random secret for session signing — use: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of this application (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# ─── 파일 스토리지 (AWS S3 또는 S3 호환 — Cloudflare R2) ──────────────────────
# AWS S3: AWS_REGION=ap-northeast-2, S3_ENDPOINT 생략
# Cloudflare R2: AWS_REGION=auto, S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# S3 호환 스토리지(R2 등) 엔드포인트. AWS S3 사용 시 비워둔다.
S3_ENDPOINT=

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender address, e.g. noreply@yourdomain.com
EMAIL_FROM=

# ─── App ─────────────────────────────────────────────────────────────────────
# Exposed to the browser — must match BETTER_AUTH_URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
